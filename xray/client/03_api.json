{
  //  支持的API服务

  "api": {
    "tag": "api",
     "listen": "127.0.0.1:10810",
    "services": [
      "HandlerService",
      "LoggerService",
      "StatsService",
      "RoutingService"
    ]
  },

"inbounds": [
   //  api的入站,通过端口转发查询本地xray api的接口，例如可以用./xray api lsi -s 127.0.0.1:10802查询xray api的入站列表
    // 也可以通过端口转发查询服务器的API
     {
      "tag": "api-in",
      "listen": "127.0.0.1",
      "port": 10802,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 10810 //,
        // "portMap": {
        //             "10802": ":10810"
        //           }
      },
      
      "sniffing": null
    }
]
}
