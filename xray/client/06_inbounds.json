{
 "inbounds": [
    
    // 一般都默认使用socks5协议作本地转发
   //https://xtls.github.io/config/inbounds/shadowsocks.html
    {
      "tag": "socks-in",
   
      "protocol": "socks",
      "listen": "127.0.0.1", // 这个是通过socks5协议做本地转发的地址
      "port": 10800, // 这个是通过socks5协议做本地转发的端口
      "settings": {
        "auth": "noauth",
        "udp": true,
        "ip": "127.0.0.1", // 当开启 UDP 时，Xray 需要知道本机的 IP 地址,但是在经过一些经过 NAT 的系统时可能导致工作异常需要修改这个参数为正确的公网IP
        "userLevel": 0
      },
      "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "routeOnly": true
            }
    },
      {
      "tag": "tun-in",
      "protocol": "tun",
      "listen": "127.0.0.1", 
        "settings": {
           "name": "XrayTun",
            "mtu": 1500,
            "gateway": ["10.0.0.1/16", "fc00::1/64"],
            "dns": ["1.1.1.1", "8.8.8.8"],
            "userLevel": 0,
            "autoSystemRoutingTable": ["0.0.0.0/0", "::/0"],
            "autoOutboundsInterface": "auto"
      },
      "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "routeOnly": false
            }
    },
  //  https://xtls.github.io/config/inbounds/http.html
    {
      "tag": "http-in",
      "protocol": "http",
      "listen": "127.0.0.1", // 这个是通过http协议做本地转发的地址
      "port": 10801 // 这个是通过http协议做本地转发的端口
    }
  ]
}
