{
 // 路由设置
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "domainMatcher": "hybrid",
   // 所谓分流，就是将符合否个条件的流量，用指定`tag`的出站协议去处理（对应配置的5.x内容）
    "rules": [

      // dns劫持
      {
        "inboundTag": ["dns-in"], // 劫持来自 DNS 查询入口的 DNS 流量，或劫持来自透明代理入站的 DNS 流量。
        "port": 53, 
       "outboundTag": "dnsOut",
         "ruleTag": "dnsJail"
       },
    
      {
        "inboundTag": ["dnsQuery"],   
        "outboundTag": "proxy",
        "ruleTag": "dnsQuery"
       },
       
      {
       "port":"53",
       "inboundTag": ["tun-in"],   
        "outboundTag": "dnsOut",
        "ruleTag": "dnsOut"
       },
      {
       "port":"853",
       "inboundTag": ["tun-in"],   
        "outboundTag": "proxy",
        "ruleTag": "dnsDoT"
       },

         //api出站回流
      {
        "inboundTag": [
          "api-in"
        ],
        "outboundTag": "api",
        "ruleTag": "api"
      },
      //mitm
       {
                "inboundTag": [
                    "tls-decrypt"
                ],
                // tls-repark 中定义了一些参数(比如IP和SNI), 不同的网站可能需要不同的参数
                // 要支持更多的网站，可以新建更多的此类 freedom 出站，然后在这里把不同的明文请求按需求路由到不同的出站重新打包回 HTTPS
                // 这里的域名来源就是 tls-decrypt 入站的 followRedirect, 所以一个本地端口就可以接受任何网站的请求并在核心中这样区分开
                "domain": [
                    "e-hentai.org"
                ],
                "outboundTag": "tls-repack"
            },
            {
                "inboundTag": [
                    "socks-in"
                ],
                // 你要 mitm 的网址
                "domain": [
                    "e-hentai.org"
                ],
             "outboundTag": "redirect-out",
             "ruleTag": "mitm"
            },

      // 域名屏蔽
      {
        "domain": [
          "geosite:category-ads-all",
          "m.baidu.com",   
          "regexp:^.*\\.doubleclick\\.net$",
          "regexp:^(?:pagead2\\.googlesyndication\\.com|s\\.youtube\\.com)$" ,
          "domain:notifications-pa.googleapis.com",
          "domain:people-pa.googleapis.com",
          "domain:redirector.googlevideo.com",
          "domain:suggestqueries.google.com",
          "domain:dingxiang-inc.com",
          "domain:hubspot.com",
          "domain:hubspotusercontent-na1.ne",
          "domain:cookielaw.org",
          "domain:right.com"
             ],
        "outboundTag": "block",
        "ruleTag": "knownAd"
        },   
      {
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "block"
      },
      {
        "inboundTag": [
         "localDNS"
        ],
        "outboundTag": "direct",
        "ruleTag": "localDNSDirect"
      },
  
    {
        "ip": [
          "127.0.0.1",
          "223.5.5.5",
          "114.114.114.114",
          "geoip:cn", 
          "geoip:private"
        ],
        "outboundTag": "direct",
        "ruleTag": "cnipDirect"
      },
       {
        "domain": [
        "geosite:cn",
        "geosite:private",
        "geosite:apple",
        "domain:apple.com",
        "domain:office.com",
        "domain:office.net",
        "domain:office365.com",
        "domain:vscode-cdn.net",
        "domain:live.com",
        "domain:sharepointonline.com",
        "domain:microsoftonline.com",
        "domain:static.microsoft",
        "domain:microsoft.com",
        "outlook.com"
      ],      
        "outboundTag": "direct",
        "ruleTag": "domainDirect"
      },

      {
        "inboundTag": [
         "http-in"
        ],
        "outboundTag": "proxy",
        "ruleTag": "httpProxy"
      },
      {
        "domain": [
         "geosite:geolocation-!cn"
        ],
        "outboundTag": "proxy"
      },
   //隧道路由（端口转发）
    {
      "inboundTag": "tunnel-src",
      "outboundTag": "tunnel-dist-xray-xhttp-reality-1"
    },
    //http代理出站路由
    {
       "inboundTag": "http-in",
      "outboundTag": "tunnel-dist-xray-xhttp-reality-2"
    },
    //反向代理1
    {
               "inboundTag": "reverse-in-vless-simple",
                "outboundTag": "reverse-out-redirect"
    },
    //反向代理2
             {
                "inboundTag": "reverse-in-vless-complex",
                "outboundTag": "reverse-out-redirect"
            }
    ]
  }
}
