{

  "outbounds": [
 {
      "tag": "proxy_vless_tls_tcp",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "YOUR_REMOTE_VPS_DOMAIN", // 替换成你的真实域名
            "port": 443,
            "users": [
              {
                "id": "808cf3a7-f4e0-4f11-8975-e4a2c2302805", // 和服务器端的一致
                "flow": "xtls-rprx-vision",      
                "encryption": "none",
                "level": 0
              }
            ]
          }
        ]
      },
      "streamSettings": {  
        "network": "raw",
        "security": "tls",  //https://xtls.github.io/config/transports/tls.html
        "tlsSettings": {
          "verifyPeerCertByName": "YOUR_REMOTE_VPS_DOMAIN",
          "serverName": "YOUR_REMOTE_VPS_DOMAIN" ,
           "alpn": [
            "http/1.1",
            "h2"
          ],
         // pinnedPeerCertSha256: "".
          "echConfigList": "https://1.1.1.1/dns-query",
          "fingerprint": "chrome",
          "allowInsecure": false 
        }
      }
    },
  
    {   
            "tag": "proxy_vless_splithttp",
            "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "YOUR_REMOTE_VPS_DOMAIN",
                        "port": 443,
                        "users": [
                            {
                                "id": "759cd425-52bc-4c7a-be70-a0a3a12cc1c3", // 与服务端一致
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "splithttp",
                "splithttpSettings": {
                    "path": "/vlesssplithttp", // 与服务端一致
                    "host": "YOUR_REMOTE_VPS_DOMAIN" // 若 "address": "" 中填的是 VPS 的 IP，此处必须填 Nginx 配置中 server_name 的值，否则会因在 Nginx 配置中启用了 ssl_reject_handshake 而连接失败
                },
                "security": "tls",
                "tlsSettings": {
                    "serverName": "YOUR_REMOTE_VPS_DOMAIN",
                     "alpn": [
                        "h3",
                        "h2",
                        "http/1.1"
                    ],
                    "fingerprint": "chrome" ,
                    "allowInsecure": false // 禁止不安全证书
                }
            }
           
        },
     {
          
           "tag": "proxy_vless_ws",
           "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "YOUR_REMOTE_VPS_DOMAIN",
                        "port": 443,
                        "users": [
                            {
                                "id": "3e0f8a38-7235-45f5-b3d0-92f0f22d3b24", // 与服务端一致
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "websocket",
                "wsSettings": {
                    "acceptProxyProtocol": false,
                    "path": "/vlessws?ed=2560", // 与服务端一致，建议增加 ?ed=2560 以启用 0-RTT 降低延迟
                    "host": "YOUR_REMOTE_VPS_DOMAIN",
                    "headers": {
                      "User-Agent": [
                                      "Mozilla/5.0 (Windows NT 10.0; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/53.0.2785.143 Safari/537.36",
                                      "Mozilla/5.0 (iPhone; CPU iPhone OS 10_0_2 like Mac OS X) AppleWebKit/601.1 (KHTML, like Gecko) CriOS/53.0.2785.109 Mobile/14A456 Safari/601.1.46"
                                    ]
                              },
                    "heartbeatPeriod": 10
              
                  },
                "security": "tls",
                "tlsSettings": {
                  "serverName": "YOUR_REMOTE_VPS_DOMAIN",
                
                    "fingerprint": "chrome"
                }
            }
        },
     {
           "tag": "proxy_vless_httpupgrade",
            "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "YOUR_REMOTE_VPS_DOMAIN",
                        "port": 443,
                        "users": [
                            {
                                "id": "38e76fc8-00a6-4be1-a430-c296ea6044c2", // 与服务端一致
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "httpupgrade",
                "httpupgradeSettings": {
                    "acceptProxyProtocol": false,
                    "path": "/vlesshttpupgrade?ed=2560", // 与服务端一致，建议增加 ?ed=2560 以启用 0-RTT 降低延迟
                    "host": "YOUR_REMOTE_VPS_DOMAIN", // 若 "address": "" 中填的是 VPS 的 IP，此处必须填 Nginx 配置中 server_name 的值，否则会因在 Nginx 配置中启用了 ssl_reject_handshake 而连接失败
                    "headers": {
                      "User-Agent": [
                                      "Mozilla/5.0 (Windows NT 10.0; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/53.0.2785.143 Safari/537.36",
                                      "Mozilla/5.0 (iPhone; CPU iPhone OS 10_0_2 like Mac OS X) AppleWebKit/601.1 (KHTML, like Gecko) CriOS/53.0.2785.109 Mobile/14A456 Safari/601.1.46"
                                    ]
                              }
                
                },
                "security": "tls",
                "tlsSettings": {
                    "serverName": "proxy.juda.autos", //可以支持prox.juda.autos,proxy.juda.autos
                    "fingerprint": "chrome"
                }
            }
        },
     {
           "tag": "proxy_grpc_vless_tcp",
           "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "YOUR_REMOTE_VPS_DOMAIN",
                        "port": 443,
                        "users": [
                            {
                                "id": "54da3b49-bbb7-41c9-89b7-398ab6bfcec0", // 与服务端一致
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "grpc",
                "grpcSettings": {
                    "authority": "YOUR_REMOTE_VPS_DOMAIN",
                    "serviceName": "/reality/grpc/h2", // 与服务端一致
                    "multiMode": true,
                    "idle_timeout": 60,
                    "health_check_timeout": 20,
                    "permit_without_stream": false,
                    "initial_windows_size": 0
                },
                "security": "tls",
                "tlsSettings": {
                    "serverName": "YOUR_REMOTE_VPS_DOMAIN",
                    "fingerprint": "chrome"
                }
            }
            
        }
 
  ]
  }
