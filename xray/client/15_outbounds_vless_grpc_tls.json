{

  "outbounds": [
//nginx->/vleesgrpc
     {
           "tag": "vless_grpc_tls",
           "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "YOUR_REMOTE_VPS_DOMAIN",
                        "port": 443,
                        "users": [
                            {
                                "id": "54da3b49-bbb7-41c9-89b7-398ab6bfcec0", // 与服务端一致
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "grpc",
                "grpcSettings": {
                    "authority": "YOUR_REMOTE_VPS_DOMAIN",
                    "serviceName": "/reality/grpc/h2", // 与服务端一致
                    "multiMode": true,
                    "idle_timeout": 60,
                    "health_check_timeout": 20,
                    "permit_without_stream": false,
                    "initial_windows_size": 0
                },
                "security": "tls",
                "tlsSettings": {
                    "serverName": "YOUR_REMOTE_VPS_DOMAIN",
                      "alpn": [
              			    "h3",
              			    "h2",
              			    "http/1.1"
              			    
                             ],
                    "fingerprint": "chrome"
                }
            }
            
        }
 
  ]
  }
