                   // "fingerprint": "randomizednoalpn", // 必填，使用 uTLS 库模拟客户端 TLS 指纹
                     "fingerprint": "chrome",
                    "serverName": "YOUR_REMOTE_VPS_DIMAIN", // 服务端 serverNames 之一
