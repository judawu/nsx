{

  // CPOY FROM https://github.com/XTLS/Xray-examples/blob/main/Hysteria2/client.jsonc
    "outbounds": [
        {
            "tag": "proxy",
            "protocol": "hysteria",
            "settings": {
                "address": "YOUR_REMORE_VPS_DOMAIN",
                "port": 10837,
                "version": 2
            },
            "streamSettings": {
                "network": "hysteria",
                 "hysteriaSettings": {
                    "version": 2,
                    "auth": "QvofbfMIil7768oFAyTpyA==" ,// Hysteria 密码,搭配 hysteria inbound 时将会被 users 覆盖
                    "udpIdleTimeout": 60,
                    "masquerade": {
                      "type": "string",
                      "content": "whoamI",
                      "headers": {
                        "User-Agent": [
                                      "Mozilla/5.0 (Windows NT 10.0; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/53.0.2785.143 Safari/537.36",
                                      "Mozilla/5.0 (iPhone; CPU iPhone OS 10_0_2 like Mac OS X) AppleWebKit/601.1 (KHTML, like Gecko) CriOS/53.0.2785.109 Mobile/14A456 Safari/601.1.46"
                                     ]
                      },
                    "statusCode": 404
                },
                "security": "tls",
                "tlsSettings": {
                    "serverName": "10837" // SNI
                },
               
                "finalmask": {
                    "udp": [
                        {
                            "type": "salamander",
                            "settings": {
                                "password": "QvofbfMIil7768oFAyTpyA==" // salamander 混淆密码
                            }
                        }
                    ],
                    "quicParams": {
                        "congestion": "bbr", // 可改为 brutal，若如此做请自行修改下面宽带
                        "brutalUp": "30 mbps",
                        "brutalDown": "100 mbps"
                    }
                }
            }
        }
    ]
}
