{
"routing": {
    "domainStrategy": "IPIfNonMatch",
    "domainMatcher": "hybrid",
    "rules": [
      {
        "ruleTag": "bt",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "block"
      },
     
      {
        "ruleTag": "selfip",
        "ip": [
          "127.0.0.1",
          "yourIP"
        ],
        "outboundTag": "direct"
      },
 
      {
        "domainMatcher": "hybrid",
        "type": "field",
        "ruleTag": "know-ad",
        "domain": [
          "regexp:^.*\\.doubleclick\\.net$",
          "regexp:^(?:pagead2\\.googlesyndication\\.com|s\\.youtube\\.com)$",
          "domain:notifications-pa.googleapis.com",
          "domain:people-pa.googleapis.com",
          "domain:redirector.googlevideo.com",
          "domain:suggestqueries.google.com",
          "domain:mip.ymclg.cn",
          "pur-oil-in-global-health-issue.colbydunlop.com"
        ],
        "outboundTag": "block"
      },
   
      {
        "ruleTag": "private-ip",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "block"
      },
      {
        "ruleTag": "cn-ip",
        "ip": [
          "geoip:cn"
        ],
        "outboundTag": "block"
      },
      {
        "ruleTag": "ad-domain",
        "domain": [
          "geosite:category-ads-all"
        ],
        "outboundTag": "block"
      }
    ]
  }
}
