      "settings": {
        "users": [
          {
            "id": "1f52cb64-23cc-46d7-aa4d-acf363097319",
            "level": 0,
            "email": "ws@vmess"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "websocket",
        "wsSettings": {
          "path": "/vmessws"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "VLESS-HTTPUPGRADE",
      "listen": "/dev/shm/nsx/vlesshttpupgrade.sock,0666",
      "protocol": "vless",
      "settings": {
        "users": [
          {
            "id": "850413a9-c769-4fa7-adae-c320fe5103b9"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
