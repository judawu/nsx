{
"inbounds": [
    {
      "tag": "VLESS-TLS-TCP",
      "listen": "/dev/shm/nsx/xray_tls_proxy.sock,0666",
      "protocol": "vless",
      "settings": {
        "users": [
          {
            
            "id": "0131f2a7-0fde-4325-9f4c-52fe1e5cf401",
            "email": "vless@tls.tcp",
            "flow": "xtls-rprx-vision",
            "level": 0
          }
        ],
        "decryption": "none",
        "fallbacks": [
       
          {
            "path": "/vlesssplithttp",
            "dest": "/dev/shm/nsx/vlesssplithttp.sock",
            "xver": 0
          },
          {
            "path": "/vlesshttpupgrade",
            "dest": "/dev/shm/nsx/vlesshttpupgrade.sock",
            "xver": 0
          },
          {
            "path": "/vlessws",
            "dest": "/dev/shm/nsx/vlessws.sock",
            "xver": 0
          },
          {
            "path": "/vmessws",
            "dest": "/dev/shm/nsx/vmessws.sock",
            "xver": 0
          },
          {
            "path": "/ss/ws",
            "dest": "4001",
          },
          {
            "path": "/ss/tcp",
            "dest": "4002",
          },
          {
            "path": "/ss/grpc",
            "dest": "4003",
          },
          {
            "path": "/ss/h2",
            "dest": "4004",
          },
          {
            "dest": "/dev/shm/nsx/trojan_xhttp_reality.sock",
            "xver": 0
          }
        ]
      },
      "streamSettings": {
        "network": "raw",
        "rawSettings": {
          "acceptProxyProtocol": false
        },
        "security": "tls",
        "tlsSettings": {
          "serverName": "tls.yourdomain",
          "rejectUnknownSni": true,
          "allowInsecure": false,
          "alpn": [    
            "h2",
            "http/1.1"
          ],
          "certificates": [
            {
               "ocspStapling": 0,
               "oneTimeLoading": false,
               "usage": "encipherment",
               "buildChain": false,
               "certificateFile": "/usr/local/nsx/certs/tls.yourdomain.pem",
               "keyFile": "/usr/local/nsx/certs/tls.yourdomain.key"
            }
          ],
          "disableSystemRoot": true,
          "enableSessionResumption": false,
          "echServerKeys": "",
          "echConfigList": ""
        }
       
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    
    {
      "tag": "VLESS-SPLITHTTP",
      "listen": "/dev/shm/nsx/vlesssplithttp.sock,0666",
      "protocol": "vless",
      "settings": {
        "users": [
          {
            "email": "VLESS@splithttp",
            "id": "c3c55d96-e8d5-41b5-b79d-fcafc1cb164c",
            "level": 0
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "splithttp",
        "splithttpSettings": {
          "path": "/vlesssplithttp"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "VLESS-WS",
      "listen": "/dev/shm/nsx/vlessws.sock,0666",
      "protocol": "vless",
      "settings": {
        "users": [
          {
            "id": "2c65bf80-35cb-491d-b057-fac6a3f74fa4"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "websocket",
        "wsSettings": {
        "acceptProxyProtocol": false,
          "path": "/vlessws"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "VMESS-WS",
      "listen": "/dev/shm/nsx/vmessws.sock,0666",
