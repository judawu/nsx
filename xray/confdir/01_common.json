{

  "log": {
    "loglevel": "error",
    "error": "/usr/local/nsx/log/xray_error.log",
    "access": "/usr/local/nsx/log/xray_access.log"
  },
 "api": {
    "tag": "api",
     "listen": "127.0.0.1:10830",
    "services": [
      "HandlerService",
      "LoggerService",
      "StatsService",
      "RoutingService"
    ]
  },
 "stats": {},
 "policy": {
    "levels": {
      "0": {
        "handshake": 2,
        "connIdle": 120,
        "statsUserUplink": true,
        "statsUserDownlink": true,
        "statsUserOnline": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "outbounds": [
    {
      "tag": "direct",
      "domainStrategy": "UseIP",
      "protocol": "freedom"
    },
    {
      "protocol": "freedom",
      "settings": {
        "redirect": "www.harvard.edu:443"
      },
      "tag": "ad-block"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }

  ]
}
 
